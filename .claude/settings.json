{
  "permissions": {
    "allow": [
      "Bash(grep -E \"^#|^[A-Z_]+=\\\\s*$|^[A-Z_]+=$\" /opt/zenaflow/.env.sample)",
      "Read(//home/appdev/.claude/**)",
      "Bash(python3 -m json.tool)",
      "Bash(tee -a /opt/zenaflow/.env.sample)",
      "Bash(sudo ln -s /opt/zenaflow/.env /opt/core/hermes_data/.env)",
      "Bash(docker compose *)"
    ],
    "additionalDirectories": [
      "/opt/core"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_start.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre_tool_use.py"
          }
        ]
      }
    ]
  }
}
